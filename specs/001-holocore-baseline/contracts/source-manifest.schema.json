{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://holocore.local/contracts/source-manifest.schema.json",
  "title": "HoloCore Source Manifest",
  "type": "object",
  "required": ["schema_version", "world_id", "sources", "aliases"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "world_id": { "type": "string", "minLength": 1 },
    "sources": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "uniqueItems": true,
      "allOf": [
        { "contains": { "type": "object", "properties": { "id": { "const": "archive" } }, "required": ["id"] } },
        { "contains": { "type": "object", "properties": { "id": { "const": "atlas" } }, "required": ["id"] } },
        { "contains": { "type": "object", "properties": { "id": { "const": "animus" } }, "required": ["id"] } }
      ],
      "items": { "$ref": "#/$defs/source" }
    },
    "aliases": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "manifest_updated_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "source": {
      "type": "object",
      "required": [
        "id", "holo_term", "upstream_name", "root", "adapter",
        "capabilities", "compatibility_aliases", "status"
      ],
      "properties": {
        "id": { "enum": ["archive", "atlas", "animus"] },
        "holo_term": { "type": "string", "minLength": 1 },
        "upstream_name": { "type": "string", "minLength": 1 },
        "root": { "type": "string", "minLength": 1 },
        "adapter": { "type": "string", "minLength": 1 },
        "capabilities": { "type": "array", "items": { "type": "string" } },
        "compatibility_aliases": { "type": "array", "items": { "type": "string" } },
        "version_hint": { "type": ["string", "null"] },
        "status": { "enum": ["configured", "ready", "warning", "error", "disabled"] },
        "last_checked_at": { "type": ["string", "null"], "format": "date-time" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
